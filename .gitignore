# >>> pivota:gitignore-managed
# Patterns auto-managed by Pivota — refreshed on every push so coverage
# stays current as new ecosystems land. Edits inside this block are
# overwritten; put project-specific entries OUTSIDE the markers.

# ── OS / editor noise ──
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.suo
*.user
*.vsidx

# ── Logs / temp ──
*.log
*.tmp
*.bak

# ── Node / npm / yarn / pnpm ──
node_modules/
npm-debug.log*
yarn-error.log*
yarn-debug.log*
pnpm-debug.log*
.pnp.*

# ── Next.js ──
.next/
out/

# ── Vite / Rollup / generic JS bundlers ──
dist/
.cache/
.parcel-cache/

# ── React / CRA ──
build/

# ── Java / Maven ──
target/
*.class
*.jar
!**/src/**/*.jar

# ── Java / Gradle ──
.gradle/
gradle-app.setting
!gradle-wrapper.jar

# ── Android ──
local.properties
*.apk
*.aab
*.iml

# ── iOS / Xcode ──
DerivedData/
*.xcuserstate
*.xcworkspace/xcuserdata/
*.xcscheme

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/

# ── Rust / Cargo ──
target/
**/*.rs.bk

# ── Go ──
vendor/
*.exe
*.test
*.out

# ── Ruby ──
.bundle/
vendor/bundle/
*.gem

# ── PHP ──
vendor/
composer.phar

# ── .NET ──
bin/
obj/
*.dll
*.pdb

# ── Testing / coverage ──
coverage/
test-results/
playwright-report/
.nyc_output/
htmlcov/
.coverage

# ── OpenCode / Pivota workspace ──
# NOTE: `.pivota/` is INTENTIONALLY NOT ignored here. Pivota commits
# `.pivota/start-dev.sh` + `.pivota/dev-script.meta.json` (the dev-server
# launcher + its drift metadata) so the preview panel can clone main and
# launch the app. Ignoring `.pivota/` made `git add .pivota/` silently
# skip the directory, and the launcher never reached GitHub.
.opencode/
opencode.json
opencode.json.bak
AGENTS.md
.opencode.session
# <<< pivota:gitignore-managed
